local _lastGC = 0

hook(rs.RenderStepped:Connect(function(dt)
	_fc += 1; tickFps(dt); purgeLos()

	if _fc % 90 == 0 then
		local now = tk()
		if now - _lastGC > 2 then _lastGC = now
			for chr in pairs(_vbufs) do if not validChr(chr) then _vbufs[chr]=nil end end
			for chr in pairs(_prevVel) do if not validChr(chr) then _prevVel[chr]=nil end end
			for chr in pairs(_accelBuf) do if not validChr(chr) then _accelBuf[chr]=nil end end
			for chr in pairs(_posHist) do if not validChr(chr) then _posHist[chr]=nil end end
			for p,ch in pairs(_chmPool) do if not validPlr(p) then kill(ch); _chmPool[p]=nil end end
			for p in pairs(_persistScore) do if not validPlr(p) then _persistScore[p]=nil end end
		end
	end

	tickNfs(dt); tickWm()
	local ctr = scrn()

	if fovRing then
		fovRing.Position = ctr
		if Cfg.aim.dynFov and _aimLck and _aimOn then
			local dr = mx(Cfg.aim.dynFovMin, Cfg.aim.fov*.4)
			fovRing.Radius=dr; fovRing.Color=c3(255,80,80); fovRing.Thickness=2
		else fovRing.Radius=Cfg.aim.fov; fovRing.Color=c3(255,255,255); fovRing.Thickness=1 end
		fovRing.Transparency=.7; fovRing.Visible=Cfg.aim.showFov and Cfg.aim.on
	end
	if fovFill then
		fovFill.Position=ctr; fovFill.Radius=fovRing and fovRing.Radius or Cfg.aim.fov
		fovFill.Color=fovRing and fovRing.Color or Color3.new(1,1,1)
		fovFill.Transparency=.05; fovFill.Visible=Cfg.aim.showFov and Cfg.aim.on
	end
	if lockTx then
		if _aimLck and _aimOn and _aimTgt then
			local nm="?"; pcall(function() nm=_aimTgt.DisplayName end)
			lockTx.Text="  LOCKED: "..nm; lockTx.Color=c3(255,80,80)
			lockTx.Position=v2(ctr.X+(fovRing and fovRing.Radius or 200)+8, ctr.Y-7)
			lockTx.Transparency=1; lockTx.Visible=true
		else lockTx.Visible=false end
	end

	if Cfg.esp.on then
		for p, ent in pairs(_ents) do local s=pcall(tickEnt, ent, dt); if not s then pcall(RemEsp, p) end end
		if _fc % 30 == 0 then for _,p in ipairs(plrs:GetPlayers()) do
			if p~=lp and not _ents[p] and validChr(p.Character) then pcall(MkEsp, p) end
		end end
	else for _,ent in pairs(_ents) do pcall(hideEnt, ent) end end

	pcall(tickXhair)
	if _pvwActive then pcall(tickPvw, dt) end
	pcall(tickTgtPnl)

	if Cfg.aim.on then
		local mb2 = uis:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
		if mb2 then
			_aimOn = true

			if _aimLck and _aimTgt then
				_persistScore[_aimTgt] = (_persistScore[_aimTgt] or 0) + dt * 30
			end

			if _aimLck and _stkTgt and Cfg.aim.sticky then
				if validPlr(_stkTgt) and validChr(_stkTgt.Character) then
					local hm = getHum(_stkTgt.Character)
					if hm and hm.Health > 0 then
						_aimTgt=_stkTgt; _stkGrace=tk()
						pcall(aimAt, _stkTgt, dt)
					else
						if Cfg.aim.gracePeriod > 0 and (tk()-_stkGrace) < Cfg.aim.gracePeriod then
							local nb = selectTarget()
							if nb and (tk()-_lastSwitch) >= Cfg.aim.switchCooldown then
								_aimTgt=nb; _stkTgt=nb; _aimLck=true; _lastSwitch=tk(); _lockTime=tk()
								_engageDist=plrDist(nb)
								initBezierPath(cam.CFrame.LookVector, ((getAimPart(nb.Character) or getRoot(nb.Character)).Position - cam.CFrame.Position).Unit)
								initOvershoot(((getAimPart(nb.Character) or getRoot(nb.Character)).Position - cam.CFrame.Position).Unit)
								pcall(aimAt, nb, dt)
							end
						else _aimLck=false; _stkTgt=nil; _aimTgt=nil end
					end
				else
					if Cfg.aim.gracePeriod > 0 and (tk()-_stkGrace) < Cfg.aim.gracePeriod then
						local nb = selectTarget()
						if nb and (tk()-_lastSwitch) >= Cfg.aim.switchCooldown then
							_aimTgt=nb; _stkTgt=nb; _aimLck=true; _lastSwitch=tk(); _lockTime=tk()
							_engageDist=plrDist(nb)
							pcall(aimAt, nb, dt)
						end
					else _aimLck=false; _stkTgt=nil; _aimTgt=nil end
				end
			end

			if not _aimLck then
				if (tk()-_lastSwitch) >= Cfg.aim.switchCooldown then
					local best = selectTarget()
					if best then
						_aimTgt=best; _stkTgt=best; _aimLck=true; _stkGrace=tk(); _lastSwitch=tk(); _lockTime=tk()
						_engageDist=plrDist(best)
						_aimTrail={from=cam.CFrame.LookVector,tangent=cam.CFrame.LookVector,t=0}
						_bzT=1; _ovState.phase=0; _flickState.active=false
						local aPart = getAimPart(best.Character) or getRoot(best.Character)
						if aPart then
							local toLook = (aPart.Position - cam.CFrame.Position).Unit
							initBezierPath(cam.CFrame.LookVector, toLook)
							initOvershoot(toLook)
						end
						pcall(aimAt, best, dt)
					else _aimTgt=nil; _aimLck=false; updOrb(nil) end
				end
			end

			pcall(updHL)
			pcall(tickTrigger, dt, _aimTgt)
		else
			if _aimOn then resetAim() end
		end
	else
		if _aimOn then resetAim() end
	end
end))

_G.REPCleanup = function()
	unhookAll()
	for p in pairs(_ents) do pcall(RemEsp, p) end
	_ents={}; _fades={}; _morphs={}; _interpBuf={}
	for p,ch in pairs(_chmPool) do kill(ch) end; _chmPool={}
	for _,ln in pairs(_xhLn) do nuke(ln) end; _xhLn={}; nuke(_xhDt); _xhDt=nil
	nuke(fovRing); fovRing=nil; nuke(fovFill); fovFill=nil; nuke(lockTx); lockTx=nil
	for _,d in pairs(_tgtPnl) do nuke(d) end
	kill(_tgtHL); _tgtHL=nil; kill(_predOrb); _predOrb=nil; kill(_navSnd); _navSnd=nil
	killPvw()
	for _,d in pairs(_wm) do nuke(d) end
	for _,n in ipairs(_nfs) do nuke(n.bg); nuke(n.tx); if n.acc then nuke(n.acc) end end; _nfs={}
	for _,n in ipairs(_nfpool) do nuke(n.bg); nuke(n.tx); if n.acc then nuke(n.acc) end end; _nfpool={}
	if Cfg.ext.graySky then setGraySky(false) end
	if Cfg.ext.fullbright then setFB(false) end
	if Cfg.ext.noFog then setNoFog(false) end
	if Cfg.ext.fmg then setFmg(false) end
	if Cfg.ext.rmTex then setRmTex(false) end
	if Cfg.ext.antiAfk then setAntiAfk(false) end
	pcall(function() cam.CameraType=Enum.CameraType.Custom end)
	_los={}; _vbufs={}; _prevVel={}; _accelBuf={}; _posHist={}; _persistScore={}
	if ui and ui.Destroy then pcall(ui.Destroy, ui) end
end
