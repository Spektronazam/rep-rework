local v2, v3, cf, c3, c3h = Vector2.new, Vector3.new, CFrame.new, Color3.fromRGB, Color3.fromHSV
local ud2, ud = UDim2.new, UDim.new
local rad, sin, cos, tan = math.rad, math.sin, math.cos, math.tan
local abs, floor, ceil, clamp = math.abs, math.floor, math.ceil, math.clamp
local huge, pi, rng, exp = math.huge, math.pi, math.random, math.exp
local mn, mx, sqrt, atan2 = math.min, math.max, math.sqrt, math.atan2
local acos, asin = math.acos, math.asin
local tk = tick
local tinsert, tremove, tcreate = table.insert, table.remove, table.create
local sfmt = string.format

local zv2, zv3, upv3 = v2(0, 0), v3(0, 0, 0), v3(0, 1, 0)
local grav = v3(0, -196.2, 0)

local _inset = zv2
pcall(function() _inset = gs:GetGuiInset() end)

local function vps() return cam.ViewportSize end
local function scrn() local s = vps(); return v2(s.X * .5, s.Y * .5) end
local function mpos() return v2(mouse.X, mouse.Y) end

local function lerp(a, b, t) return a + (b - a) * t end
local function damp(c, g, sp, dt) return lerp(c, g, 1 - exp(-sp * dt * 60)) end
local function sstep(t) return t * t * (3 - 2 * t) end
local function sstep5(t) return t*t*t*(t*(t*6-15)+10) end
local function eoc(t) local u = 1-t; return 1 - u*u*u end

local function hpcol(p)
	p = clamp(p, 0, 1)
	return p > .5 and Color3.new(clamp(2*(1-p),0,1), 1, 0) or Color3.new(1, clamp(2*p,0,1), 0)
end

local _cn = {}
local function hook(conn) if conn then _cn[#_cn+1] = conn end; return conn end
local function unhookAll()
	for i = #_cn, 1, -1 do
		local c = _cn[i]
		if c and c.Connected then pcall(c.Disconnect, c) end
		_cn[i] = nil
	end
end

local function nuke(d) if d then pcall(function() d.Visible = false; d:Remove() end) end end
local function kill(inst) if inst then pcall(inst.Destroy, inst) end end

local function mkDraw(kind, props)
	local s, d = pcall(Drawing.new, kind)
	if not s or not d then return nil end
	if props then for k, val in pairs(props) do d[k] = val end end
	d.Visible = props and props.Visible or false
	d.ZIndex = props and props.ZIndex or 50
	return d
end

local function mkLine(p) return mkDraw("Line", {
	From=p and p.From or zv2, To=p and p.To or zv2,
	Color=p and p.Color or Color3.new(1,1,1), Thickness=p and p.Thickness or 1,
	Transparency=p and p.Transparency or 1, Visible=p and p.Visible or false,
	ZIndex=p and p.ZIndex or 50
}) end

local function mkText(p) return mkDraw("Text", {
	Text=p and p.Text or "", Size=p and p.Size or 14,
	Font=p and p.Font or Drawing.Fonts.Plex, Position=p and p.Position or zv2,
	Center=p and p.Center or false, Outline=p and (p.Outline ~= nil and p.Outline or true) or true,
	Color=p and p.Color or Color3.new(1,1,1), Transparency=p and p.Transparency or 1,
	Visible=p and p.Visible or false, ZIndex=p and p.ZIndex or 50
}) end

local function mkRect(p) return mkDraw("Square", {
	Size=p and p.Size or v2(10,10), Position=p and p.Position or zv2,
	Color=p and p.Color or Color3.new(1,1,1), Filled=p and p.Filled or false,
	Thickness=p and p.Thickness or 1, Transparency=p and p.Transparency or 1,
	Visible=p and p.Visible or false, ZIndex=p and p.ZIndex or 50
}) end

local function mkCirc(p) return mkDraw("Circle", {
	Position=p and p.Position or zv2, Radius=p and p.Radius or 10,
	Color=p and p.Color or Color3.new(1,1,1), Filled=p and p.Filled or false,
	Thickness=p and p.Thickness or 1, Transparency=p and p.Transparency or 1,
	NumSides=p and p.NumSides or 64, Visible=p and p.Visible or false,
	ZIndex=p and p.ZIndex or 50
}) end

local function mkTri(p) return mkDraw("Triangle", {
	PointA=p and p.PointA or zv2, PointB=p and p.PointB or zv2, PointC=p and p.PointC or zv2,
	Color=p and p.Color or Color3.new(1,1,1), Filled=p and p.Filled or false,
	Thickness=p and p.Thickness or 1, Transparency=p and p.Transparency or 1,
	Visible=p and p.Visible or false, ZIndex=p and p.ZIndex or 50
}) end

local function validPlr(p) if not p then return false end; local s,r = pcall(function() return p.Parent ~= nil and plrs:FindFirstChild(p.Name) ~= nil end); return s and r end
local function validChr(c) return c and c.Parent ~= nil end
local function getHum(c) return validChr(c) and c:FindFirstChildOfClass("Humanoid") or nil end
local function getRoot(c) return validChr(c) and (c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("Torso")) or nil end
local function getHead(c) return validChr(c) and c:FindFirstChild("Head") or nil end
local function isR15(c) return validChr(c) and c:FindFirstChild("UpperTorso") ~= nil end
local function alive(c) local h = getHum(c); return h and h.Health > 0 end
local function sameTeam(p) return lp.Team and p.Team and lp.Team == p.Team end

local function getWpn(c)
	if not validChr(c) then return nil end
	for _, ch in ipairs(c:GetChildren()) do
		if ch:IsA("Tool") or ch:IsA("HopperBin") then return ch.Name end
	end
end

local function plrDist(p)
	if not p or not p.Character then return huge end
	local r = getRoot(p.Character)
	return r and (r.Position - cam.CFrame.Position).Magnitude or huge
end

local _rp = RaycastParams.new()
_rp.FilterType = Enum.RaycastFilterType.Exclude
_rp.IgnoreWater = true

local _los = {}
local _losTTL = 0.08
local _losPurge = 0
local _losProbes = {"Head","UpperTorso","HumanoidRootPart","LowerTorso","LeftUpperArm","RightUpperArm"}

local function checkVis(chr)
	if not validChr(chr) then return false end
	local r = getRoot(chr)
	if not r then return false end
	local now = tk()
	local cc = _los[chr]
	if cc and (now - cc.t) < _losTTL then return cc.r end
	local fl = {cam}
	local lc = lp.Character
	if lc then fl[2] = lc end
	_rp.FilterDescendantsInstances = fl
	local hits, tot = 0, 0
	local org = cam.CFrame.Position
	local look = cam.CFrame.LookVector
	for _, pn in ipairs(_losProbes) do
		local pt = chr:FindFirstChild(pn)
		if pt and pt:IsA("BasePart") then
			local dir = pt.Position - org
			if look:Dot(dir.Unit) < -.1 then continue end
			tot += 1
			local rc = ws:Raycast(org, dir, _rp)
			if not rc or rc.Instance:IsDescendantOf(chr) then hits += 1 end
		end
	end
	local vis = tot > 0 and (hits/tot) >= .25
	_los[chr] = {r=vis, t=now}
	return vis
end

local function purgeLos()
	local now = tk()
	if now - _losPurge < 1 then return end
	_losPurge = now
	for k, e in pairs(_los) do
		if (now - e.t) > .4 or not validChr(k) then _los[k] = nil end
	end
end

