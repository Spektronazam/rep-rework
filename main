local _predOrb
local function mkOrb()
	kill(_predOrb); _predOrb=nil
	pcall(function()
		local p = Instance.new("Part"); p.Name="ro_"..tostring(rng(100,999))
		p.Shape=Enum.PartType.Ball; p.Size=v3(.8,.8,.8); p.Material=Enum.Material.Neon
		p.Color=c3(0,255,255); p.Transparency=1; p.Anchored=true; p.CanCollide=false; p.CastShadow=false
		p.Parent=ws; _predOrb=p
	end)
end
mkOrb()

local function updOrb(pos)
	if not Cfg.aim.predVis or not _aimOn or not pos then
		if _predOrb then pcall(function() _predOrb.Transparency=1 end) end; return
	end
	if not _predOrb or not _predOrb.Parent then mkOrb() end
	if _predOrb then pcall(function() _predOrb.Position=pos; _predOrb.Transparency=.35; _predOrb.Color=c3(0,255,255) end) end
end

local _tgtHL
local function mkHL()
	kill(_tgtHL); _tgtHL=nil
	pcall(function()
		local hl = Instance.new("Highlight"); hl.Name="rh_"..tostring(rng(100,999))
		hl.FillTransparency=.7; hl.OutlineTransparency=0; hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; hl.Enabled=false
		local ok = pcall(function() hl.Parent=cg end)
		if not ok then pcall(function() hl.Parent=lp:WaitForChild("PlayerGui",2) end) end; _tgtHL=hl
	end)
end
mkHL()

local function updHL()
	if not _tgtHL then mkHL() end; if not _tgtHL then return end
	if Cfg.aim.hlTgt and _aimTgt and validChr(_aimTgt.Character) then
		_tgtHL.Adornee=_aimTgt.Character; _tgtHL.FillColor=c3(255,40,40); _tgtHL.OutlineColor=c3(255,60,60); _tgtHL.Enabled=true
	else _tgtHL.Enabled=false; _tgtHL.Adornee=nil end
end

local function pnoise(seed, freq, amp)
	local t = tk()*freq + seed
	return (sin(t*1.3)*.5 + sin(t*2.7+.8)*.3 + cos(t*.9+1.6)*.2) * amp
end

local function brownNoise(prev, rate, amp, dt)
	local drift = (rng() - .5) * 2 * rate * dt
	return clamp(prev + drift, -amp, amp)
end

local _bnX, _bnY, _bnZ = 0, 0, 0

local function cubicHermite(p0, m0, p1, m1, t)
	local t2, t3 = t*t, t*t*t
	return p0*(2*t3-3*t2+1) + m0*(t3-2*t2+t) + p1*(-2*t3+3*t2) + m1*(t3-t2)
end

local function quadBezier(a, ctrl, b, t)
	local u = 1-t
	return a*(u*u) + ctrl*(2*u*t) + b*(t*t)
end

local function cubicBezier(a, c1, c2, b, t)
	local u = 1-t
	return a*(u*u*u) + c1*(3*u*u*t) + c2*(3*u*t*t) + b*(t*t*t)
end

local function getSmoothedVel(chr)
	if not chr then return zv3 end
	local r = getRoot(chr); if not r then return zv3 end
	local vel = r.AssemblyLinearVelocity or zv3
	if vel.Magnitude < Cfg.aim.deadzone then return zv3 end
	local buf = _vbufs[chr]
	if not buf then buf = {s=tcreate(Cfg.aim.velFrames), i=0, c=0}; _vbufs[chr]=buf end
	local mxf = mx(1, Cfg.aim.velFrames)
	buf.i = (buf.i % mxf) + 1; buf.s[buf.i] = vel; buf.c = mn(buf.c+1, mxf)
	local sum = zv3
	local w = 0
	for i = 1, buf.c do
		local sv = buf.s[((buf.i - i) % mxf) + 1]
		if sv then
			local age = i - 1
			local weight = exp(-age * .3)
			sum = sum + sv * weight
			w += weight
		end
	end
	return w > 0 and sum / w or zv3
end

local function getAccel(chr)
	if not chr or not Cfg.aim.accelPred then return zv3 end
	local vel = getSmoothedVel(chr)
	local ab = _accelBuf[chr]
	if not ab then ab = {prev=vel, smooth=zv3}; _accelBuf[chr]=ab end
	local raw = (vel - ab.prev) * _fps
	ab.prev = vel
	ab.smooth = ab.smooth + (raw - ab.smooth) * .15
	return ab.smooth
end

local function recordPos(chr)
	if not chr then return end
	local r = getRoot(chr); if not r then return end
	local hist = _posHist[chr]
	if not hist then hist = tcreate(20); _posHist[chr] = hist end
	local now = tk()
	tinsert(hist, 1, {p=r.Position, v=r.AssemblyLinearVelocity or zv3, t=now})
	while #hist > 20 do tremove(hist) end
end

local function getBacktrackPos(chr)
	if not Cfg.aim.backtrack then return nil end
	local hist = _posHist[chr]; if not hist or #hist < 2 then return nil end
	local delay = Cfg.aim.backtrackMs / 1000
	local now = tk()
	for i = 1, #hist-1 do
		local a, b = hist[i], hist[i+1]
		if (now - b.t) >= delay and (now - a.t) <= delay then
			local frac = clamp((delay - (now - a.t)) / mx((a.t - b.t), .001), 0, 1)
			return lerp(a.p, b.p, frac)
		end
	end
	local last = hist[#hist]
	if last and (now - last.t) <= delay + .1 then return last.p end
	return nil
end

local function bestVisiblePart(chr)
	if not Cfg.aim.multiPoint then return nil end
	local fl = {cam}; local lc = lp.Character; if lc then fl[2] = lc end
	_rp.FilterDescendantsInstances = fl
	local org = cam.CFrame.Position
	local ctr = scrn()
	local best, bestD = nil, huge
	for _, pn in ipairs(_AIM_PARTS) do
		local pt = chr:FindFirstChild(pn)
		if pt and pt:IsA("BasePart") then
			local rc = ws:Raycast(org, pt.Position - org, _rp)
			if not rc or rc.Instance:IsDescendantOf(chr) then
				local sp, onS = cam:WorldToViewportPoint(pt.Position)
				if onS then
					local d = (ctr - v2(sp.X, sp.Y)).Magnitude
					if d < bestD then bestD = d; best = pt end
				end
			end
		end
	end
	return best
end

local function closestPartToXhair(chr)
	local best, bestD = nil, huge; local mp = mpos()
	for _, pn in ipairs(_AIM_PARTS) do
		local pt = chr:FindFirstChild(pn)
		if pt and pt:IsA("BasePart") then
			local sp, onS = cam:WorldToViewportPoint(pt.Position)
			if onS then local d = (mp - v2(sp.X,sp.Y)).Magnitude; if d < bestD then bestD=d; best=pt end end
		end
	end
	return best
end

local function getAimPart(chr)
	if not validChr(chr) then return nil end
	if Cfg.aim.part == "Closest" then return closestPartToXhair(chr) end
	if Cfg.aim.part == "Smart" then
		local vis = bestVisiblePart(chr)
		if vis then return vis end
	end
	return chr:FindFirstChild(Cfg.aim.part) or getHead(chr) or getRoot(chr)
end

local function predictPos(tpos, vel, accel, chr)
	if not vel or vel.Magnitude < .1 then return tpos end
	local pg = getPingSec()

	if Cfg.aim.backtrack and chr then
		local bt = getBacktrackPos(chr)
		if bt then
			local blend = clamp(Cfg.aim.backtrackMs / 200, 0, .6)
			tpos = lerp(tpos, bt, blend)
		end
	end

	if Cfg.aim.predMode == "Ping" then
		local pred = tpos + vel * pg * 1.35
		if accel and accel.Magnitude > .5 then
			pred = pred + accel * pg * pg * .35
		end
		local dirChange = _accelBuf[chr] and _accelBuf[chr].smooth or zv3
		if dirChange.Magnitude > 20 then
			pred = pred + dirChange.Unit * pg * 2
		end
		return pred
	else
		local cdist = (tpos - cam.CFrame.Position).Magnitude
		local et = cdist / mx(1, 1400)
		local totalT = et + pg * .4
		local pred = tpos + vel * totalT + .5 * grav * et * et
		if accel and accel.Magnitude > .5 then
			pred = pred + accel * totalT * .35
		end
		return pred
	end
end

local function resolvePos(chr, aimPart)
	if not Cfg.aim.resolver then return aimPart.Position end
	local hum = getHum(chr); if not hum then return aimPart.Position end
	local vel = getSmoothedVel(chr)
	if vel.Magnitude < 3 then return aimPart.Position end
	local moveDir = vel.Unit
	local camFwd = (aimPart.Position - cam.CFrame.Position).Unit
	local cross = moveDir:Cross(camFwd)
	local lateralComp = cross.Magnitude
	if lateralComp < .1 then return aimPart.Position end
	local rightOff = moveDir:Cross(upv3).Unit * lateralComp * .45
	local speed = vel.Magnitude
	local scaledOff = rightOff * clamp(speed / 30, .2, 1.5)
	return aimPart.Position + scaledOff
end

local function distAdaptPart(chr)
	if not Cfg.aim.distAdapt then return nil end
	local r = getRoot(chr); if not r then return nil end
	local d = (r.Position - cam.CFrame.Position).Magnitude
	if d < 30 then
		return chr:FindFirstChild("Head") or chr:FindFirstChild("UpperTorso")
	elseif d < 80 then
		return chr:FindFirstChild("UpperTorso") or chr:FindFirstChild("Head")
	else
		return chr:FindFirstChild("HumanoidRootPart") or chr:FindFirstChild("UpperTorso")
	end
end

local function getTargets()
	local out = {}
	local ctr = scrn(); local cp = cam.CFrame.Position
	local fov = Cfg.aim.fov
	if Cfg.aim.dynFov and _aimLck and _aimOn then fov = mx(Cfg.aim.dynFovMin, fov * .4) end
	for _, p in ipairs(plrs:GetPlayers()) do
		if p == lp then continue end
		if not validPlr(p) or not validChr(p.Character) then continue end
		local chr = p.Character; local hum = getHum(chr); local root = getRoot(chr)
		if not hum or hum.Health <= 0 or not root then continue end
		if Cfg.aim.teamChk and sameTeam(p) then continue end
		if Cfg.aim.visChk and not checkVis(chr) then continue end
		local wd = (root.Position - cp).Magnitude
		if Cfg.aim.distChk and wd > Cfg.esp.range then continue end
		local ap
		if Cfg.aim.distAdapt then ap = distAdaptPart(chr) end
		if not ap then ap = getAimPart(chr) end
		if not ap then continue end
		local sp, onS = cam:WorldToViewportPoint(ap.Position)
		local spos = v2(sp.X, sp.Y); local cd = (ctr - spos).Magnitude
		if onS and cd <= fov then
			out[#out+1] = {plr=p, aim=ap, sd=cd, wd=wd, hp=hum.Health, mhp=hum.MaxHealth}
		end
	end
	return out
end

local function scoreTarget(t)
	local sc = 1000
	sc -= t.sd * 3.0
	sc -= (t.wd / 10) * 1.0
	sc -= (t.hp / mx(t.mhp, 1)) * 150
	if _persistScore[t.plr] then
		sc += _persistScore[t.plr] * 0.8
	end
	if Cfg.aim.visChk and checkVis(t.plr.Character) then sc += 250 end
	local vel = getSmoothedVel(t.plr.Character)
	if vel.Magnitude < 5 then sc += 80 end
	return sc
end

local function selectTarget()
	local tgts = getTargets(); if #tgts == 0 then return nil end
	local pri = Cfg.aim.priority
	if pri == "Distance" then table.sort(tgts, function(a,b) return a.wd < b.wd end)
	elseif pri == "Health" then table.sort(tgts, function(a,b) return a.hp < b.hp end)
	elseif pri == "Smart" then table.sort(tgts, function(a,b) return scoreTarget(a) > scoreTarget(b) end)
	else table.sort(tgts, function(a,b) return a.sd < b.sd end) end
	return tgts[1].plr
end

local function genBezierCtrl(from, to)
	local mid = (from + to) * .5
	local dist = (to - from).Magnitude
	local jit = Cfg.aim.bezierJitter
	local off = v3(
		(rng()-.5)*2 * dist * jit,
		(rng()-.5)*2 * dist * jit * .6,
		(rng()-.5)*2 * dist * jit * .3
	)
	return mid + off
end

local function initBezierPath(fromLook, toLook)
	_bzFrom = fromLook
	_bzTo = toLook
	_bzPeak = genBezierCtrl(fromLook, toLook)
	_bzT = 0
end

local function tickBezier(dt, sf)
	_bzT = clamp(_bzT + dt * sf * 55, 0, 1)
	local t = sstep5(_bzT)
	return quadBezier(_bzFrom, _bzPeak, _bzTo, t)
end

local function initOvershoot(targetLook)
	if not Cfg.aim.overshoot then return end
	local ovStr = Cfg.aim.overshootStr
	local ovDir = (targetLook - cam.CFrame.LookVector)
	if ovDir.Magnitude < .001 then return end
	local ovAmount = ovDir.Unit * ovStr * (.7 + rng() * .6)
	_ovState.phase = 1
	_ovState.timer = 0
	_ovState.ovPos = targetLook + ovAmount
end

local function tickOvershoot(dt, targetLook)
	if _ovState.phase == 0 then return targetLook end
	_ovState.timer += dt
	if _ovState.phase == 1 then
		local dur = .06 + rng() * .04
		if _ovState.timer >= dur then
			_ovState.phase = 2; _ovState.timer = 0
			return _ovState.ovPos
		end
		local t = sstep(_ovState.timer / dur)
		return lerp(cam.CFrame.LookVector, _ovState.ovPos, t)
	elseif _ovState.phase == 2 then
		local dur = .08 + rng() * .06
		if _ovState.timer >= dur then
			_ovState.phase = 0; return targetLook
		end
		local t = eoc(_ovState.timer / dur)
		return lerp(_ovState.ovPos, targetLook, t)
	end
	return targetLook
end

local function initFlick(fromLook, toLook)
	local angle = acos(clamp(fromLook:Dot(toLook), -1, 1))
	if angle < rad(Cfg.aim.flickThresh) then return false end
	_flickState.active = true; _flickState.t = 0
	_flickState.startLook = fromLook; _flickState.endLook = toLook
	_flickState.dur = clamp(angle / rad(180) * .15 + .03, .03, .18)
	return true
end

local function tickFlick(dt)
	if not _flickState.active then return nil end
	_flickState.t += dt
	if _flickState.t >= _flickState.dur then
		_flickState.active = false
		return _flickState.endLook
	end
	local t = _flickState.t / _flickState.dur
	local curve = 1 - (1-t)*(1-t)*(1-t)
	local mid = (_flickState.startLook + _flickState.endLook).Unit
	local ctrl = (mid + v3((rng()-.5)*.02, (rng()-.5)*.01, 0)).Unit
	return quadBezier(_flickState.startLook, ctrl, _flickState.endLook, curve).Unit
end

local function applyCone(look)
	if not Cfg.aim.aimCone or Cfg.aim.coneDeg <= 0 then return look end
	local coneRad = rad(Cfg.aim.coneDeg)
	local angle = (rng()-.5) * 2 * coneRad
	local rot = rng() * pi * 2
	local right = look:Cross(upv3)
	if right.Magnitude < .001 then right = look:Cross(v3(1,0,0)) end
	right = right.Unit
	local up2 = right:Cross(look).Unit
	local deflect = (right * cos(rot) + up2 * sin(rot)) * sin(angle)
	return (look + deflect).Unit
end

local function processReaction(tgt)
	if not Cfg.aim.reactionSim then _rxnReady = true; _rxnQueue = nil; return end
	if _rxnQueue and _rxnQueue.tgt == tgt then
		if tk() >= _rxnQueue.readyAt then _rxnReady = true; _rxnQueue = nil end
		return
	end
	local baseMs = Cfg.aim.reactionMs
	local jitter = (rng() - .5) * baseMs * .4
	local delay = (baseMs + jitter) / 1000
	_rxnQueue = {tgt=tgt, readyAt=tk()+delay}
	_rxnReady = false
end

local function tickTrigger(dt, tgt)
	if not Cfg.aim.triggerbot or not _aimLck or not tgt then _trigState.armed = false; return end
	local chr = tgt.Character; if not validChr(chr) then return end
	local head = getHead(chr); if not head then return end
	local sp, onS = cam:WorldToViewportPoint(head.Position)
	if not onS then _trigState.armed = false; return end
	local ctr = scrn(); local d = (ctr - v2(sp.X,sp.Y)).Magnitude
	local threshold = 8 + (plrDist(tgt) / 100) * 3
	if d <= threshold then
		if not _trigState.armed then
			_trigState.armed = true
			_trigState.timer = Cfg.aim.triggerDelay / 1000 + (rng()-.5)*.02
		end
		_trigState.timer -= dt
		if _trigState.timer <= 0 then
			pcall(function() mouse1click() end)
			_trigState.timer = Cfg.aim.triggerBurst and (.04 + rng()*.03) or (Cfg.aim.triggerDelay / 1000 + rng()*.02)
			_trigState.burstN += 1
			if Cfg.aim.triggerBurst and _trigState.burstN >= (2 + rng(0,2)) then
				_trigState.armed = false; _trigState.burstN = 0
			end
		end
	else
		_trigState.armed = false; _trigState.burstN = 0
	end
end

local function aimAt(tgt, dt)
	if not tgt or not validPlr(tgt) or not validChr(tgt.Character) then return end
	local hum = getHum(tgt.Character); if not hum or hum.Health <= 0 then return end

	processReaction(tgt)
	if not _rxnReady then updOrb(nil); return end

	recordPos(tgt.Character)

	local ap
	if Cfg.aim.distAdapt then ap = distAdaptPart(tgt.Character) end
	if not ap then ap = getAimPart(tgt.Character) end
	if not ap then return end

	if Cfg.aim.multiPoint and Cfg.aim.visChk then
		local visPart = bestVisiblePart(tgt.Character)
		if visPart then ap = visPart end
	end

	local rawPos = resolvePos(tgt.Character, ap)
	local vel = getSmoothedVel(tgt.Character)
	local accel = getAccel(tgt.Character)

	local offset = v3(Cfg.misc.offX, Cfg.misc.offY, Cfg.misc.offZ)
	if Cfg.misc.autoAdj then
		local r = getRoot(tgt.Character)
		local pd = r and (r.Position - cam.CFrame.Position).Magnitude or 100
		if Cfg.misc.aaMode == "Proximity" then offset = offset * clamp(1-(pd/200),.1,2)
		else offset = offset * clamp(pd/200,.5,3) end
	end

	local hSt = hum:GetState()
	if hSt == Enum.HumanoidStateType.Jumping or hSt == Enum.HumanoidStateType.Freefall then
		offset = offset + v3(0, Cfg.misc.jumpOff, 0)
	end

	if Cfg.misc.shake then
		local si = Cfg.misc.shakeStr * .1
		_bnX = brownNoise(_bnX, 15, si, dt)
		_bnY = brownNoise(_bnY, 12, si, dt)
		_bnZ = brownNoise(_bnZ, 8, si * .4, dt)
		offset = offset + v3(_bnX, _bnY, _bnZ)
	end

	local finalPos = predictPos(rawPos + offset, vel, accel, tgt.Character)

	if Cfg.aim.humanize then
		local hs = Cfg.aim.humanStr * .12
		local micro = v3(
			pnoise(42.7, 14, hs) + pnoise(91.2, 31, hs * .3),
			pnoise(87.3, 13, hs) + pnoise(23.8, 29, hs * .3),
			pnoise(63.1, 11, hs * .4)
		)
		local engageT = clamp((tk() - _lockTime) / 2, 0, 1)
		micro = micro * lerp(1.5, .6, engageT)
		finalPos = finalPos + micro
	end

	if Cfg.aim.aimCone then
		local dir = (finalPos - cam.CFrame.Position)
		if dir.Magnitude > .01 then
			local look = applyCone(dir.Unit)
			finalPos = cam.CFrame.Position + look * dir.Magnitude
		end
	end

	updOrb(finalPos)

	local newLook = (finalPos - cam.CFrame.Position)
	if newLook.Magnitude < .001 then return end
	newLook = newLook.Unit
	local curLook = cam.CFrame.LookVector

	local angleDelta = acos(clamp(curLook:Dot(newLook), -1, 1))

	local sf
	if Cfg.aim.smooth == 0 then sf = 1
	elseif Cfg.aim.adaptSmooth then
		local baseSf = clamp(1-(Cfg.aim.smooth/11),.05,1)
		local angFactor = clamp(angleDelta / rad(20), .2, 3)
		local distFactor = clamp(_engageDist / 200, .5, 1.5)
		local velFactor = vel.Magnitude > 15 and 1.3 or 1
		sf = clamp(baseSf * angFactor * distFactor * velFactor, .03, 1)
	else sf = clamp(1-(Cfg.aim.smooth/11),.05,1) end

	if Cfg.aim.flick and _flickState.active then
		local flickLook = tickFlick(dt)
		if flickLook then
			cam.CFrame = cf(cam.CFrame.Position, cam.CFrame.Position + flickLook)
			return
		end
	end

	if Cfg.aim.flick and angleDelta > rad(Cfg.aim.flickThresh) and not _flickState.active then
		if initFlick(curLook, newLook) then
			initOvershoot(newLook)
			return
		end
	end

	local blendLook

	if Cfg.aim.overshoot and _ovState.phase > 0 then
		blendLook = tickOvershoot(dt, newLook)
	elseif Cfg.aim.bezier and sf < .9 then
		if _bzT >= .98 or (_bzTo - newLook).Magnitude > .15 then
			initBezierPath(curLook, newLook)
		end
		blendLook = tickBezier(dt, sf)
		if blendLook.Magnitude < .001 then blendLook = newLook end
		blendLook = blendLook.Unit
	elseif Cfg.aim.humanize and sf < .95 then
		_aimTrail.t = clamp(_aimTrail.t + dt * sf * 60, 0, 1)
		blendLook = cubicHermite(curLook, _aimTrail.tangent*.5, newLook, zv3, sstep(_aimTrail.t))
		if blendLook.Magnitude < .001 then blendLook = newLook end
		blendLook = blendLook.Unit
		if _aimTrail.t >= .95 then _aimTrail.from=finalPos; _aimTrail.tangent=newLook; _aimTrail.t=0 end
	else
		local tgtCF = cf(cam.CFrame.Position, finalPos)
		if Cfg.aim.mouseMethod and mousemoverel then
			local sp, onS = cam:WorldToViewportPoint(finalPos)
			if onS then
				local ctr = scrn()
				local dx = (sp.X - ctr.X) * sf
				local dy = (sp.Y - ctr.Y) * sf
				pcall(mousemoverel, dx, dy)
			end
			return
		end
		cam.CFrame = cam.CFrame:Lerp(tgtCF, sf)
		return
	end

	if Cfg.aim.mouseMethod and mousemoverel then
		local projPt = cam.CFrame.Position + blendLook * 100
		local sp, onS = cam:WorldToViewportPoint(projPt)
		if onS then
			local ctr = scrn()
			pcall(mousemoverel, sp.X - ctr.X, sp.Y - ctr.Y)
		end
	else
		cam.CFrame = cf(cam.CFrame.Position, cam.CFrame.Position + blendLook)
	end
end

local function resetAim()
	_aimOn=false; _aimLck=false; _aimTgt=nil; _stkTgt=nil; _stkGrace=0
	_aimTrail={from=zv3,tangent=zv3,t=0}
	_bzT=1; _ovState.phase=0; _flickState.active=false
	_rxnQueue=nil; _rxnReady=true
	_trigState.armed=false; _trigState.burstN=0
	_bnX=0; _bnY=0; _bnZ=0
	_persistScore = {}
	updOrb(nil); updHL()
	pcall(function() cam.CameraType = Enum.CameraType.Custom end)
end

local _xhLn = {}
local _xhDt

local function tickXhair()
	if not Cfg.misc.xhair then
		for _, ln in pairs(_xhLn) do if ln then ln.Visible=false end end
		if _xhDt then _xhDt.Visible=false end; return
	end
	local ctr = scrn()
	local sz, gap, thk, col = Cfg.misc.xhSz, Cfg.misc.xhGap, Cfg.misc.xhThk, Cfg.misc.xhCol
	if Cfg.misc.xhDyn and _aimOn and _aimLck then sz=mx(2,sz*.4); gap=mx(1,gap*.4) end
	for i=1,4 do if not _xhLn[i] then _xhLn[i]=mkLine({ZIndex=9990}) end end
	local l,r,u,d = _xhLn[1],_xhLn[2],_xhLn[3],_xhLn[4]
	l.From=v2(ctr.X-sz-gap,ctr.Y); l.To=v2(ctr.X-gap,ctr.Y)
	r.From=v2(ctr.X+gap,ctr.Y); r.To=v2(ctr.X+sz+gap,ctr.Y)
	u.From=v2(ctr.X,ctr.Y-sz-gap); u.To=v2(ctr.X,ctr.Y-gap)
	d.From=v2(ctr.X,ctr.Y+gap); d.To=v2(ctr.X,ctr.Y+sz+gap)
	for _, ln in ipairs({l,r,u,d}) do ln.Color=col; ln.Thickness=thk; ln.Transparency=1; ln.Visible=true end
	if Cfg.misc.xhDot then
		if not _xhDt then _xhDt=mkCirc({Radius=2,Filled=true,NumSides=16,ZIndex=9991}) end
		_xhDt.Position=ctr; _xhDt.Color=col; _xhDt.Transparency=1; _xhDt.Visible=true
	else if _xhDt then _xhDt.Visible=false end end
end

local _origSky,_origAmb,_origOutd,_origFogC,_origFogE,_origFogS,_origBri,_origGS
local _rmTex = {}
local _afkCn

local function saveLtg() pcall(function()
	_origAmb=ltg.Ambient; _origOutd=ltg.OutdoorAmbient; _origFogC=ltg.FogColor
	_origFogE=ltg.FogEnd; _origFogS=ltg.FogStart; _origBri=ltg.Brightness; _origGS=ltg.GlobalShadows
end) end
saveLtg()

local function setGraySky(on)
	if on then
		local sky = ltg:FindFirstChildOfClass("Sky"); if sky then _origSky=sky; sky.Parent=nil end
		pcall(function() ltg.Ambient=c3(128,128,128); ltg.OutdoorAmbient=c3(128,128,128); ltg.FogColor=c3(128,128,128); ltg.FogEnd=9e9 end)
	else
		if _origSky then pcall(function() _origSky.Parent=ltg end); _origSky=nil end
		pcall(function() if _origAmb then ltg.Ambient=_origAmb end; if _origOutd then ltg.OutdoorAmbient=_origOutd end; if _origFogC then ltg.FogColor=_origFogC end; if _origFogE then ltg.FogEnd=_origFogE end end)
	end
end

local function setFB(on)
	if on then pcall(function() ltg.Ambient=Color3.new(1,1,1); ltg.OutdoorAmbient=Color3.new(1,1,1); ltg.Brightness=2; ltg.GlobalShadows=false end)
	else pcall(function() if _origAmb then ltg.Ambient=_origAmb end; if _origOutd then ltg.OutdoorAmbient=_origOutd end; if _origBri then ltg.Brightness=_origBri end; if _origGS~=nil then ltg.GlobalShadows=_origGS end end) end
end

local function setNoFog(on)
	if on then pcall(function() ltg.FogStart=0; ltg.FogEnd=1e10 end)
	else pcall(function() if _origFogS then ltg.FogStart=_origFogS end; if _origFogE then ltg.FogEnd=_origFogE end end) end
end

local function setFmg(on)
	if on then
		for _,x in ipairs(ltg:GetChildren()) do if x:IsA("PostEffect") then pcall(function() x.Enabled=false end) end end
		pcall(function() ltg.GlobalShadows=false; ltg.FogEnd=1e10; ltg.Brightness=1; settings().Rendering.QualityLevel=Enum.QualityLevel.Level01 end)
	else
		for _,x in ipairs(ltg:GetChildren()) do if x:IsA("PostEffect") then pcall(function() x.Enabled=true end) end end
		pcall(function() if _origGS~=nil then ltg.GlobalShadows=_origGS end; if _origFogE then ltg.FogEnd=_origFogE end; if _origBri then ltg.Brightness=_origBri end; settings().Rendering.QualityLevel=Enum.QualityLevel.Automatic end)
	end
end

local function setRmTex(on)
	if on then
		for _,obj in ipairs(ws:GetDescendants()) do pcall(function()
			if obj:IsA("Texture") or obj:IsA("Decal") then _rmTex[#_rmTex+1]={o=obj,p=obj.Parent}; obj.Parent=nil end
		end) end; pushNf(sfmt("Stripped %d textures",#_rmTex),2,"info")
	else local ct=0; for _,d in ipairs(_rmTex) do pcall(function() if d.o and d.p then d.o.Parent=d.p; ct+=1 end end) end; _rmTex={}; pushNf(sfmt("Restored %d textures",ct),2,"info") end
end

local function setAntiAfk(on)
	if on then
		if _afkCn then pcall(function() _afkCn:Disconnect() end) end
		pcall(function() local vu=game:GetService("VirtualUser"); _afkCn=lp.Idled:Connect(function() pcall(function() vu:CaptureController(); vu:ClickButton2(v2(0,0)) end) end) end)
	else if _afkCn then pcall(function() _afkCn:Disconnect() end); _afkCn=nil end end
end

local _tgtPnl = {
	bg=mkRect({Filled=true,Color=c3(12,12,18),ZIndex=9970}),
	acc=mkRect({Filled=true,Color=c3(80,90,230),ZIndex=9971}),
	nm=mkText({Size=13,ZIndex=9972,Font=Drawing.Fonts.Plex}),
	hp=mkText({Size=11,ZIndex=9972,Font=Drawing.Fonts.Plex}),
	dst=mkText({Size=11,ZIndex=9972,Font=Drawing.Fonts.Plex}),
	wpn=mkText({Size=11,ZIndex=9972,Font=Drawing.Fonts.Plex}),
	hpBar=mkRect({Filled=true,ZIndex=9972}),
	hpBg=mkRect({Filled=true,Color=c3(40,40,45),ZIndex=9971}),
}
local _tgtPnlOn = true

local function hideTgtPnl() for _,d in pairs(_tgtPnl) do if d and d.Visible~=nil then d.Visible=false end end end

local function tickTgtPnl()
	if not _tgtPnlOn or not _aimOn or not _aimLck or not _aimTgt then hideTgtPnl(); return end
	local p = _aimTgt
	if not validPlr(p) or not validChr(p.Character) then hideTgtPnl(); return end
	local chr=p.Character; local hum=getHum(chr); local root=getRoot(chr)
	if not hum or not root then hideTgtPnl(); return end
	local pad=8; local pW,pH=180,72; local pX=10; local pY=vps().Y-pH-40
	if _tgtPnl.bg then _tgtPnl.bg.Size=v2(pW,pH); _tgtPnl.bg.Position=v2(pX,pY); _tgtPnl.bg.Transparency=.88; _tgtPnl.bg.Visible=true end
	if _tgtPnl.acc then _tgtPnl.acc.Size=v2(pW,2); _tgtPnl.acc.Position=v2(pX,pY); _tgtPnl.acc.Color=c3(255,60,60); _tgtPnl.acc.Transparency=1; _tgtPnl.acc.Visible=true end
	local tx,ty=pX+pad,pY+6
	if _tgtPnl.nm then _tgtPnl.nm.Text=p.DisplayName.." (@"..p.Name..")"; _tgtPnl.nm.Position=v2(tx,ty); _tgtPnl.nm.Color=c3(255,80,80); _tgtPnl.nm.Transparency=1; _tgtPnl.nm.Visible=true; ty+=16 end
	local mxh=mx(hum.MaxHealth,1); local pct=clamp(hum.Health/mxh,0,1); local hc=hpcol(pct)
	if _tgtPnl.hp then _tgtPnl.hp.Text=sfmt("HP: %d/%d (%.0f%%)",floor(hum.Health),floor(hum.MaxHealth),pct*100); _tgtPnl.hp.Position=v2(tx,ty); _tgtPnl.hp.Color=hc; _tgtPnl.hp.Transparency=1; _tgtPnl.hp.Visible=true; ty+=14 end
	local bry=ty+1; local brw=pW-pad*2; local brh=4
	if _tgtPnl.hpBg then _tgtPnl.hpBg.Size=v2(brw,brh); _tgtPnl.hpBg.Position=v2(tx,bry); _tgtPnl.hpBg.Transparency=.7; _tgtPnl.hpBg.Visible=true end
	if _tgtPnl.hpBar then _tgtPnl.hpBar.Size=v2(mx(1,brw*pct),brh); _tgtPnl.hpBar.Position=v2(tx,bry); _tgtPnl.hpBar.Color=hc; _tgtPnl.hpBar.Transparency=1; _tgtPnl.hpBar.Visible=true end
	ty=bry+brh+3
	local dd=(root.Position-cam.CFrame.Position).Magnitude
	if _tgtPnl.dst then _tgtPnl.dst.Text=sfmt("Dist: %dm",floor(dd)); _tgtPnl.dst.Position=v2(tx,ty); _tgtPnl.dst.Color=c3(180,180,200); _tgtPnl.dst.Transparency=1; _tgtPnl.dst.Visible=true end
	local wpn=getWpn(chr)
	if _tgtPnl.wpn then
		if wpn then _tgtPnl.wpn.Text="Wpn: "..wpn; _tgtPnl.wpn.Position=v2(tx+90,ty); _tgtPnl.wpn.Color=c3(220,180,60); _tgtPnl.wpn.Transparency=1; _tgtPnl.wpn.Visible=true
		else _tgtPnl.wpn.Visible=false end
	end
end

local function onJoin(p)
	if p == lp then return end
	hook(p.CharacterAdded:Connect(function()
		task.defer(function()
			task.wait(.15+rng()*.1)
			if validPlr(p) and validChr(p.Character) and Cfg.esp.on then MkEsp(p) end
		end)
	end))
	hook(p.CharacterRemoving:Connect(function()
		_vbufs[p.Character]=nil; _accelBuf[p.Character]=nil; _prevVel[p.Character]=nil; _posHist[p.Character]=nil
	end))
	if p.Character and Cfg.esp.on then MkEsp(p) end
end

for _, p in ipairs(plrs:GetPlayers()) do onJoin(p) end
hook(plrs.PlayerAdded:Connect(onJoin))
hook(plrs.PlayerRemoving:Connect(function(p)
	pcall(RemEsp, p)
	if p.Character then _vbufs[p.Character]=nil; _accelBuf[p.Character]=nil; _prevVel[p.Character]=nil; _posHist[p.Character]=nil end
	_persistScore[p] = nil
end))
hook(ws:GetPropertyChangedSignal("CurrentCamera"):Connect(function() cam = ws.CurrentCamera end))

