local _navSnd
do
	local s, snd = pcall(function()
		local x = Instance.new("Sound")
		x.SoundId = "rbxassetid://106128357156633"
		x.Volume = 5
		x.Parent = cg or lp:FindFirstChildOfClass("PlayerGui")
		return x
	end)
	if s then _navSnd = snd end
end
local function playNav() if _navSnd then pcall(function() _navSnd:Stop(); _navSnd:Play() end) end end

local _fpsBuf = tcreate(60)
local _fpsI = 0
local _fps = 60

local function tickFps(dt)
	_fpsI = (_fpsI % 60) + 1
	_fpsBuf[_fpsI] = dt
	local n = mn(#_fpsBuf, 60)
	if n == 0 then return end
	local sum = 0
	for i = 1, n do sum += (_fpsBuf[i] or .016) end
	_fps = floor(n / sum + .5)
end

local function getPing()
	local pg = 50
	pcall(function() pg = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue() end)
	return floor(clamp(pg, 1, 9999))
end
local function getPingSec() return clamp(getPing() / 1000, .005, .5) end

local NCOL = {
	info = Color3.new(1,1,1), success = c3(80,255,80),
	warning = c3(255,200,40), error = c3(255,80,80),
}
local _nfs, _nfpool = {}, {}

local function mkNfSlot()
	local bg = mkRect({Filled=true, Color=Color3.new(0,0,0), Transparency=0, ZIndex=9998, Thickness=0})
	local tx = mkText({Size=13, ZIndex=10000})
	local ac = mkRect({Filled=true, Color=c3(80,90,230), Transparency=0, ZIndex=9999})
	if not bg or not tx then return nil end
	return {bg=bg, tx=tx, acc=ac}
end

local function pushNf(msg, dur, nt)
	dur = dur or 3; nt = nt or "info"
	local slot = tremove(_nfpool) or mkNfSlot()
	if not slot then return end
	slot.msg = msg; slot.born = tk(); slot.life = dur
	slot.alpha = 0; slot.offX = 250; slot.color = NCOL[nt] or NCOL.info
	_nfs[#_nfs+1] = slot
end

local function tickNfs(dt)
	local vp = vps()
	local bx, by, pad, now = vp.X - 14, 52, 10, tk()
	local rm = {}
	for i, n in ipairs(_nfs) do
		local age = now - n.born
		local fi = clamp(age / .28, 0, 1)
		local fo = clamp((n.life - age) / .45, 0, 1)
		local a = mn(fi, fo)
		n.alpha = a; n.offX = damp(n.offX, 0, .08, dt)
		if age > n.life then
			rm[#rm+1] = i; n.bg.Visible = false; n.tx.Visible = false
			if n.acc then n.acc.Visible = false end
		else
			n.tx.Text = n.msg; n.tx.Color = n.color
			local tb = n.tx.TextBounds or v2(#n.msg*7, 14)
			local bw, bh = tb.X + pad*2 + 4, tb.Y + pad
			local px, py = bx - bw + n.offX, by + (i-1)*(bh+5)
			n.bg.Size = v2(bw,bh); n.bg.Position = v2(px,py)
			n.bg.Transparency = a*.85; n.bg.Color = c3(15,15,20); n.bg.Visible = true
			if n.acc then n.acc.Size = v2(3,bh); n.acc.Position = v2(px,py); n.acc.Transparency = a; n.acc.Color = c3(80,90,230); n.acc.Visible = true end
			n.tx.Position = v2(px+pad+4, py+pad*.32); n.tx.Transparency = a; n.tx.Visible = true
		end
	end
	for j = #rm, 1, -1 do
		local idx = rm[j]; local n = tremove(_nfs, idx)
		n.bg.Visible = false; n.tx.Visible = false
		if n.acc then n.acc.Visible = false end
		_nfpool[#_nfpool+1] = n
	end
end

local _wm = {
	bg = mkRect({Filled=true, Color=c3(12,12,18), ZIndex=9990}),
	acc = mkRect({Filled=true, Color=c3(80,90,230), ZIndex=9991}),
	txt = mkText({Size=12, ZIndex=9992, Font=Drawing.Fonts.Plex}),
}
local _wmOn = true

local function tickWm()
	if not _wmOn then
		if _wm.bg then _wm.bg.Visible = false end
		if _wm.acc then _wm.acc.Visible = false end
		if _wm.txt then _wm.txt.Visible = false end
		return
	end
	local str = sfmt("REP+  |  FPS: %d  |  Ping: %dms  |  %s", _fps, getPing(), os.date("%H:%M:%S"))
	local pad = 8
	if _wm.txt then
		_wm.txt.Text = str; _wm.txt.Color = c3(220,220,230)
		local tb = _wm.txt.TextBounds or v2(#str*7, 14)
		local bw, bh = tb.X+pad*2, tb.Y+pad
		if _wm.bg then _wm.bg.Size = v2(bw,bh); _wm.bg.Position = v2(10,8); _wm.bg.Transparency = .88; _wm.bg.Visible = true end
		if _wm.acc then _wm.acc.Size = v2(bw,2); _wm.acc.Position = v2(10,8); _wm.acc.Transparency = 1; _wm.acc.Visible = true end
		_wm.txt.Position = v2(10+pad, 8+pad*.32); _wm.txt.Transparency = 1; _wm.txt.Visible = true
	end
end

local _ents = {}
local _fades = {}
local _morphs = {}
local _chmPool = {}
local _interpBuf = {}

local function espCol(p, vis)
	if sameTeam(p) then return Cfg.esp.showTeam and Cfg.esp.teamCol or nil end
	return vis and Cfg.esp.visCol or Cfg.esp.hidCol
end

local function drawCornerBox(lines, x, y, w, h, col, thk, alpha, frac)
	local cw, ch = floor(w*frac), floor(h*frac)
	local segs = {
		{x,y,x+cw,y},{x,y,x,y+ch},{x+w,y,x+w-cw,y},{x+w,y,x+w,y+ch},
		{x,y+h,x+cw,y+h},{x,y+h,x,y+h-ch},{x+w,y+h,x+w-cw,y+h},{x+w,y+h,x+w,y+h-ch},
	}
	for i = 1, mn(8, #lines) do
		local ln = lines[i]
		if ln then local s = segs[i]; ln.From = v2(s[1],s[2]); ln.To = v2(s[3],s[4]); ln.Color = col; ln.Thickness = thk; ln.Transparency = alpha; ln.Visible = true end
	end
end

local function fixSkel(ent, chr)
	local ns = isR15(chr) and SKEL15 or SKEL6
	if ent.rig == ns then return end
	for _, ln in ipairs(ent.skelLn) do nuke(ln) end
	ent.skelLn = tcreate(#ns)
	for i = 1, #ns do ent.skelLn[i] = mkLine({ZIndex=51}) end
	ent.rig = ns
end

local RemEsp, MkEsp

MkEsp = function(p)
	if p == lp then return end
	if _ents[p] then RemEsp(p) end
	local chr = p.Character
	local sk = (chr and isR15(chr)) and SKEL15 or SKEL6
	local ent = {
		plr=p, box=mkRect({ZIndex=52}), corners=tcreate(8),
		nm=mkText({Center=true,Size=13,ZIndex=53}), dstTx=mkText({Center=true,Size=11,ZIndex=53}),
		hpTx=mkText({Center=true,Size=11,ZIndex=53}), wpnTx=mkText({Center=true,Size=10,ZIndex=53}),
		flagTx=mkText({Center=false,Size=10,ZIndex=53}),
		hpOl=mkRect({Filled=false,Color=Color3.new(0,0,0),ZIndex=51}),
		hpBg=mkRect({Filled=true,Color=c3(50,50,50),ZIndex=52}),
		hpFl=mkRect({Filled=true,ZIndex=53}),
		trc=mkLine({ZIndex=51}), skelLn=tcreate(#sk),
		oofTri=mkTri({Filled=true,ZIndex=48}),
		rig=sk, glowLn=nil, tier=1,
	}
	for i = 1, 8 do ent.corners[i] = mkLine({ZIndex=52}) end
	for i = 1, #sk do ent.skelLn[i] = mkLine({ZIndex=51}) end
	if Cfg.esp.glow then ent.glowLn = tcreate(8); for i=1,8 do ent.glowLn[i] = mkLine({ZIndex=50,Thickness=Cfg.esp.glowStr+2}) end end
	_ents[p] = ent
	_fades[p] = {cur=0,goal=1,dead=false,born=tk()}
	_morphs[p] = Cfg.esp.corner and 1 or 0
	_interpBuf[p] = {sx=0,sy=0,bw=40,bh=80,topY=0,botY=80}
	if Cfg.esp.chams then pcall(function()
		local hl = Instance.new("Highlight"); hl.Name = "rc_"..tostring(rng(1000,9999))
		hl.FillTransparency=.65; hl.OutlineTransparency=.3; hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
		hl.Adornee=chr; hl.Enabled=true; hl.Parent=cg or lp:FindFirstChildOfClass("PlayerGui")
		_chmPool[p] = hl
	end) end
end

RemEsp = function(p)
	local ent = _ents[p]
	if ent then
		nuke(ent.box); nuke(ent.nm); nuke(ent.dstTx); nuke(ent.hpTx)
		nuke(ent.wpnTx); nuke(ent.flagTx); nuke(ent.hpOl); nuke(ent.hpBg)
		nuke(ent.hpFl); nuke(ent.trc); nuke(ent.oofTri)
		for _, ln in ipairs(ent.corners) do nuke(ln) end
		for _, ln in ipairs(ent.skelLn) do nuke(ln) end
		if ent.glowLn then for _, ln in ipairs(ent.glowLn) do nuke(ln) end end
		_ents[p] = nil
	end
	_fades[p] = nil; _morphs[p] = nil; _interpBuf[p] = nil
	if p.Character then _los[p.Character] = nil end
	local ch = _chmPool[p]; if ch then kill(ch); _chmPool[p] = nil end
end

local function hideEnt(ent)
	if not ent then return end
	local all = {ent.box,ent.nm,ent.dstTx,ent.hpTx,ent.wpnTx,ent.flagTx,ent.hpOl,ent.hpBg,ent.hpFl,ent.trc,ent.oofTri}
	for _, d in ipairs(all) do if d then d.Visible = false end end
	for _, ln in ipairs(ent.corners) do if ln then ln.Visible = false end end
	for _, ln in ipairs(ent.skelLn) do if ln then ln.Visible = false end end
	if ent.glowLn then for _, ln in ipairs(ent.glowLn) do if ln then ln.Visible = false end end end
end

local function drawOof(ent, wpos, col, alpha)
	if not ent.oofTri then return end
	local ctr = scrn(); local vs = vps()
	local sp3 = cam:WorldToViewportPoint(wpos)
	local sp = v2(sp3.X, sp3.Y); local dir = sp - ctr
	if dir.Magnitude < 1 then ent.oofTri.Visible = false; return end
	dir = dir.Unit; local m = 50
	local hw, hh = vs.X*.5-m, vs.Y*.5-m
	local sx = abs(dir.X) > .001 and abs(hw/dir.X) or huge
	local sy = abs(dir.Y) > .001 and abs(hh/dir.Y) or huge
	local sc = mn(sx,sy); local ep = ctr + dir*sc
	local prp = v2(-dir.Y, dir.X); local asz = 10
	ent.oofTri.PointA = ep+dir*asz; ent.oofTri.PointB = ep-dir*(asz*.4)+prp*(asz*.5)
	ent.oofTri.PointC = ep-dir*(asz*.4)-prp*(asz*.5)
	ent.oofTri.Color = col; ent.oofTri.Transparency = alpha*.8; ent.oofTri.Filled = true; ent.oofTri.Visible = true
end

local function calcTier(dist)
	if dist < 120 then return 1 end
	if dist < 350 then return 2 end
	return dist < 600 and 3 or 4
end

local _fc = 0

local function tickEnt(ent, dt)
	local p = ent.plr
	if not validPlr(p) then RemEsp(p); return end
	local chr = p.Character
	if not validChr(chr) then hideEnt(ent); return end
	local root = getRoot(chr); local head = getHead(chr); local hum = getHum(chr)
	if not root then hideEnt(ent); return end
	local camPos = cam.CFrame.Position
	local dist = (root.Position - camPos).Magnitude
	ent.tier = calcTier(dist)
	if ent.tier > 1 and (_fc % ent.tier) ~= 0 then return end
	local fs = _fades[p]
	if not fs then fs = {cur=0,goal=1,dead=false,born=tk()}; _fades[p] = fs end
	if hum then
		if hum.Health <= 0 then if not fs.dead then fs.dead=true; fs.goal=0 end
		else if fs.dead then fs.dead=false; fs.goal=1; fs.born=tk() end; fs.goal=1 end
	else if not fs.dead then fs.dead=true; fs.goal=0 end end
	if abs(fs.cur - fs.goal) > .003 then fs.cur = damp(fs.cur, fs.goal, .05, dt*ent.tier) else fs.cur = fs.goal end
	if Cfg.esp.teamChk and sameTeam(p) and not Cfg.esp.showTeam then hideEnt(ent); return end
	if dist > Cfg.esp.range then hideEnt(ent); return end
	local vis = not Cfg.esp.visChk or checkVis(chr)
	local col = espCol(p, vis)
	if not col then hideEnt(ent); return end
	local rs3, onScr = cam:WorldToViewportPoint(root.Position)
	if not onScr then
		hideEnt(ent); if Cfg.esp.oofArrows then drawOof(ent, root.Position, col, fs.cur) end; return
	end
	if ent.oofTri then ent.oofTri.Visible = false end
	local hp = head and head.Position or (root.Position + v3(0,1.5,0))
	local ts3 = cam:WorldToViewportPoint(hp + v3(0,.6,0))
	local bs3 = cam:WorldToViewportPoint(root.Position - v3(0,3,0))
	local rawH = mx(4, abs(ts3.Y - bs3.Y)); local rawW = rawH * .55
	local ib = _interpBuf[p]
	if ib and Cfg.esp.interpPos then
		local spd = .12
		ib.sx = damp(ib.sx, rs3.X, spd, dt); ib.sy = damp(ib.sy, rs3.Y, spd, dt)
		ib.bw = damp(ib.bw, rawW, spd, dt); ib.bh = damp(ib.bh, rawH, spd, dt)
		ib.topY = damp(ib.topY, ts3.Y, spd, dt); ib.botY = damp(ib.botY, bs3.Y, spd, dt)
	else
		if not ib then ib = {}; _interpBuf[p] = ib end
		ib.sx=rs3.X; ib.sy=rs3.Y; ib.bw=rawW; ib.bh=rawH; ib.topY=ts3.Y; ib.botY=bs3.Y
	end
	local boxH, boxW = ib.bh, ib.bw; local boxX = ib.sx - boxW*.5; local boxY = ib.topY
	local age = tk() - (fs.born or tk()); local bFade = sstep(clamp(age/.4, 0, 1)); local alpha = fs.cur * bFade
	local mt = Cfg.esp.corner and 1 or 0
	if not _morphs[p] then _morphs[p] = mt end
	_morphs[p] = damp(_morphs[p], mt, .08, dt)
	local mfrac = lerp(.5, .25, _morphs[p])
	local chm = _chmPool[p]
	if Cfg.esp.chams then
		if not chm then pcall(function()
			local hl = Instance.new("Highlight"); hl.Name="rc_"..tostring(rng(1000,9999))
			hl.FillTransparency=.65; hl.OutlineTransparency=.3; hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
			hl.Adornee=chr; hl.Enabled=true; hl.Parent=cg or lp:FindFirstChildOfClass("PlayerGui")
			_chmPool[p]=hl; chm=hl
		end) end
		if chm then pcall(function() chm.Adornee=chr; chm.FillColor=col; chm.OutlineColor=col; chm.Enabled=true end) end
	else if chm then pcall(function() chm.Enabled=false end) end end
	if Cfg.esp.boxes then
		if ent.box then ent.box.Visible = false end
		drawCornerBox(ent.corners, boxX, boxY, boxW, boxH, col, Cfg.esp.boxThk, alpha, mfrac)
		if Cfg.esp.glow and ent.glowLn then
			drawCornerBox(ent.glowLn, boxX, boxY, boxW, boxH, Color3.new(col.R*.6,col.G*.6,col.B*.6), Cfg.esp.glowStr+2, alpha*.3, mfrac)
		end
	else
		if ent.box then ent.box.Visible = false end
		for _, ln in ipairs(ent.corners) do if ln then ln.Visible = false end end
		if ent.glowLn then for _, ln in ipairs(ent.glowLn) do if ln then ln.Visible = false end end end
	end
	if Cfg.esp.names and ent.nm then
		local dn, un = p.DisplayName, p.Name
		ent.nm.Text = (dn ~= un) and (dn.." ("..un..")") or un
		ent.nm.Position = v2(ib.sx, boxY-16); ent.nm.Color = col; ent.nm.Transparency = alpha; ent.nm.Visible = true
	elseif ent.nm then ent.nm.Visible = false end
	local bY = ib.botY + 2
	if Cfg.esp.dist and ent.dstTx then
		ent.dstTx.Text = sfmt("[%dm]", floor(dist)); ent.dstTx.Position = v2(ib.sx, bY)
		ent.dstTx.Color = col; ent.dstTx.Transparency = alpha; ent.dstTx.Visible = true; bY += 14
	elseif ent.dstTx then ent.dstTx.Visible = false end
	if Cfg.esp.weapon and ent.wpnTx then
		local wpn = getWpn(chr)
		if wpn then ent.wpnTx.Text = "["..wpn.."]"; ent.wpnTx.Position = v2(ib.sx, bY); ent.wpnTx.Color = c3(220,180,60); ent.wpnTx.Transparency = alpha; ent.wpnTx.Visible = true; bY += 13
		else ent.wpnTx.Visible = false end
	elseif ent.wpnTx then ent.wpnTx.Visible = false end
	if Cfg.esp.flags and ent.flagTx then
		local fl = {}
		if getWpn(chr) then fl[#fl+1] = "ARMED" end
		if hum and hum.Health / mx(hum.MaxHealth,1) < .25 then fl[#fl+1] = "LOW" end
		if hum then local st = hum:GetState(); if st == Enum.HumanoidStateType.Freefall or st == Enum.HumanoidStateType.Jumping then fl[#fl+1] = "AIR" end end
		if #fl > 0 then ent.flagTx.Text = table.concat(fl," | "); ent.flagTx.Position = v2(boxX+boxW+4, boxY); ent.flagTx.Color = c3(255,200,80); ent.flagTx.Transparency = alpha; ent.flagTx.Visible = true
		else ent.flagTx.Visible = false end
	elseif ent.flagTx then ent.flagTx.Visible = false end
	if Cfg.esp.hbar and hum then
		local mxh = mx(hum.MaxHealth,1); local pct = clamp(hum.Health/mxh,0,1)
		local bW = mx(3,floor(boxW*.07)); local bX = boxX-bW-3
		local bH = mx(1, boxH*bFade); local bYp = boxY + (boxH-bH)
		local fH = mx(1, bH*pct); local hc = hpcol(pct)
		if ent.hpOl then ent.hpOl.Size=v2(bW+2,bH+2); ent.hpOl.Position=v2(bX-1,bYp-1); ent.hpOl.Transparency=alpha; ent.hpOl.Visible=true end
		if ent.hpBg then ent.hpBg.Size=v2(bW,bH); ent.hpBg.Position=v2(bX,bYp); ent.hpBg.Transparency=alpha*.5; ent.hpBg.Visible=true end
		if ent.hpFl then ent.hpFl.Size=v2(bW,fH); ent.hpFl.Position=v2(bX,bYp+(bH-fH)); ent.hpFl.Color=hc; ent.hpFl.Transparency=alpha; ent.hpFl.Visible=true end
		if Cfg.esp.htxt and ent.hpTx then
			ent.hpTx.Text=sfmt("%d/%d",floor(hum.Health),floor(hum.MaxHealth)); ent.hpTx.Position=v2(bX+bW*.5,bYp-15)
			ent.hpTx.Color=hc; ent.hpTx.Transparency=alpha; ent.hpTx.Visible=true
		elseif ent.hpTx then ent.hpTx.Visible=false end
	else
		if ent.hpOl then ent.hpOl.Visible=false end; if ent.hpBg then ent.hpBg.Visible=false end
		if ent.hpFl then ent.hpFl.Visible=false end; if ent.hpTx then ent.hpTx.Visible=false end
	end
	if Cfg.esp.tracers and ent.trc then
		local vs = vps(); local fp
		if Cfg.esp.tracerOrigin == "Top" then fp = v2(vs.X*.5,0)
		elseif Cfg.esp.tracerOrigin == "Center" then fp = v2(vs.X*.5,vs.Y*.5)
		else fp = v2(vs.X*.5, vs.Y) end
		ent.trc.From = fp; ent.trc.To = v2(ib.sx,ib.sy); ent.trc.Color = col; ent.trc.Transparency = alpha; ent.trc.Visible = true
	elseif ent.trc then ent.trc.Visible = false end
	if Cfg.esp.skel then
		fixSkel(ent, chr); local bones = ent.rig
		for i, bone in ipairs(bones) do
			local ln = ent.skelLn[i]; if not ln then continue end
			local p1, p2 = chr:FindFirstChild(bone[1]), chr:FindFirstChild(bone[2])
			if p1 and p2 and p1:IsA("BasePart") and p2:IsA("BasePart") then
				local s1,o1 = cam:WorldToViewportPoint(p1.Position); local s2,o2 = cam:WorldToViewportPoint(p2.Position)
				if o1 and o2 then ln.From=v2(s1.X,s1.Y); ln.To=v2(s2.X,s2.Y); ln.Color=col; ln.Transparency=alpha; ln.Visible=true
				else ln.Visible=false end
			else ln.Visible=false end
		end
		for i = #bones+1, #ent.skelLn do if ent.skelLn[i] then ent.skelLn[i].Visible=false end end
	else for _, ln in ipairs(ent.skelLn) do if ln then ln.Visible=false end end end
end

local _pvwActive = false
local _pvwGui, _pvwFrame, _pvwVp, _pvwCam, _pvwWm = nil,nil,nil,nil,nil
local _pvwDraw = {}
local _pvwAng, _pvwT, _pvwMorph = 0, 0, 0
local _pvwOrig = {}

