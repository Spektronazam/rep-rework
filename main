}

local function vpProject(vpf, vpc, wp)
	local lp3 = vpc.CFrame:PointToObjectSpace(wp)
	if lp3.Z >= 0 then return zv2, false end
	local hfov = tan(rad(vpc.FieldOfView*.5))
	local as = vpf.AbsoluteSize; local ap = vpf.AbsolutePosition
	if as.X < 1 or as.Y < 1 then return zv2, false end
	local asp = as.X / as.Y
	local nx = -lp3.X / (-lp3.Z*hfov*asp); local ny = -lp3.Y / (-lp3.Z*hfov)
	return v2((nx*.5+.5)*as.X+ap.X+_inset.X, (ny*.5+.5)*as.Y+ap.Y+_inset.Y), true
end

local function killPvw()
	for _, d in pairs(_pvwDraw) do
		if type(d)=="table" then for _, sub in pairs(d) do nuke(sub) end else nuke(d) end
	end
	_pvwDraw={}; kill(_pvwGui); _pvwGui=nil; _pvwFrame=nil; _pvwVp=nil; _pvwCam=nil; _pvwWm=nil; _pvwActive=false; _pvwOrig={}
end

local function spawnPvw()
	killPvw()
	local ok = pcall(function()
		local gui = Instance.new("ScreenGui"); gui.Name="RP_"..tostring(rng(100,999))
		gui.ResetOnSpawn=false; gui.ZIndexBehavior=Enum.ZIndexBehavior.Sibling; gui.DisplayOrder=100
		local pOk = pcall(function() gui.Parent = cg end)
		if not pOk or not gui.Parent then gui.Parent = lp:WaitForChild("PlayerGui",5) end; _pvwGui=gui
		local fr = Instance.new("Frame"); fr.Size=ud2(0,200,0,300); fr.Position=ud2(1,-224,.5,-150)
		fr.BackgroundColor3=c3(10,10,14); fr.BackgroundTransparency=.05; fr.BorderSizePixel=0; fr.Parent=gui; _pvwFrame=fr
		local crn = Instance.new("UICorner"); crn.CornerRadius=ud(0,8); crn.Parent=fr
		local stk = Instance.new("UIStroke"); stk.Color=c3(80,90,230); stk.Thickness=2; stk.Transparency=.1; stk.Parent=fr
		local ttl = Instance.new("TextLabel"); ttl.Size=ud2(1,0,0,26); ttl.BackgroundTransparency=1
		ttl.Text="3D PREVIEW"; ttl.TextColor3=c3(200,200,220); ttl.Font=Enum.Font.GothamBold; ttl.TextSize=11; ttl.Parent=fr
		local al = Instance.new("Frame"); al.Size=ud2(1,-16,0,1); al.Position=ud2(0,8,0,26)
		al.BackgroundColor3=c3(80,90,230); al.BackgroundTransparency=.4; al.BorderSizePixel=0; al.Parent=fr
		local vp = Instance.new("ViewportFrame"); vp.Size=ud2(1,-16,1,-36); vp.Position=ud2(0,8,0,30)
		vp.BackgroundTransparency=1; vp.LightColor=c3(240,240,255); vp.LightDirection=v3(-1,-.8,-.6); vp.Ambient=c3(160,160,180); vp.Parent=fr; _pvwVp=vp
		local cm = Instance.new("Camera"); cm.FieldOfView=35; cm.CFrame=cf(v3(8,3.5,0),v3(0,3,0)); cm.Parent=vp; vp.CurrentCamera=cm; _pvwCam=cm
		local wm = Instance.new("WorldModel"); wm.Parent=vp; _pvwWm=wm; _pvwOrig={}
		for _, info in ipairs(DUMMY) do
			local pt = Instance.new("Part"); pt.Name=info.n; pt.Size=info.s; pt.CFrame=cf(info.p)
			pt.Anchored=true; pt.CanCollide=false; pt.CastShadow=false
			pt.TopSurface=Enum.SurfaceType.Smooth; pt.BottomSurface=Enum.SurfaceType.Smooth; pt.Material=Enum.Material.SmoothPlastic
			if info.t then pt.Transparency=1 else pt.Color=info.c or c3(128,128,128) end
			pt.Parent=wm; _pvwOrig[info.n]=info.p
		end
		local fl = Instance.new("Part"); fl.Name="Floor"; fl.Size=v3(20,.1,20); fl.CFrame=cf(v3(0,-.05,0))
		fl.Anchored=true; fl.CanCollide=false; fl.CastShadow=false; fl.Color=c3(22,22,28)
		fl.Material=Enum.Material.SmoothPlastic; fl.TopSurface=Enum.SurfaceType.Smooth; fl.BottomSurface=Enum.SurfaceType.Smooth; fl.Parent=wm
	end)
	if not ok then killPvw(); pushNf("3D Preview failed",3,"error"); return end
	_pvwDraw.corners={}; for i=1,8 do _pvwDraw.corners[i]=mkLine({ZIndex=9985,Color=c3(0,255,0)}) end
	_pvwDraw.nm=mkText({Text="Player123",Size=12,Center=true,ZIndex=9986})
	_pvwDraw.dstTx=mkText({Text="[42m]",Size=10,Center=true,ZIndex=9986})
	_pvwDraw.hpOl=mkRect({Filled=false,Color=Color3.new(0,0,0),ZIndex=9984})
	_pvwDraw.hpBg=mkRect({Filled=true,Color=c3(50,50,50),ZIndex=9985})
	_pvwDraw.hpFl=mkRect({Filled=true,Color=c3(0,255,0),ZIndex=9986})
	_pvwDraw.trc=mkLine({ZIndex=9983})
	_pvwDraw.skelLn={}; for i=1,#SKEL15 do _pvwDraw.skelLn[i]=mkLine({ZIndex=9985}) end
	_pvwDraw.wpnTx=mkText({Text="[AK-47]",Size=9,Center=true,ZIndex=9986,Color=c3(220,180,60)})
	_pvwActive=true; pushNf("3D Preview active",2,"success")
end

local function tickPvw(dt)
	if not _pvwActive or not _pvwVp or not _pvwCam or not _pvwWm then return end
	_pvwAng += dt*.4; _pvwT += dt
	local cx, cz = sin(_pvwAng)*9, cos(_pvwAng)*9
	_pvwCam.CFrame = cf(v3(cx,3.2,cz), v3(0,3,0))
	local bob = sin(_pvwT*1.8)*.08
	for _, pt in ipairs(_pvwWm:GetChildren()) do
		if pt:IsA("BasePart") and pt.Name ~= "Floor" then
			local og = _pvwOrig[pt.Name]; if og then pt.CFrame = cf(og + v3(0,bob,0)) end
		end
	end
	local col = Cfg.esp.visCol
	local hdPt = _pvwWm:FindFirstChild("Head"); local rtPt = _pvwWm:FindFirstChild("HumanoidRootPart")
	if not hdPt or not rtPt then return end
	local tp, tOk = vpProject(_pvwVp, _pvwCam, hdPt.CFrame.Position + v3(0,.6,0))
	local cp, cOk = vpProject(_pvwVp, _pvwCam, rtPt.CFrame.Position)
	local bp, bOk = vpProject(_pvwVp, _pvwCam, rtPt.CFrame.Position - v3(0,3,0))
	if not (tOk and cOk and bOk) then
		for _, d in pairs(_pvwDraw) do
			if type(d)=="table" then for _, sub in pairs(d) do if sub and sub.Visible ~= nil then sub.Visible=false end end
			elseif d and d.Visible ~= nil then d.Visible=false end
		end; return
	end
	local bxH = mx(4,abs(tp.Y-bp.Y)); local bxW = bxH*.55; local bxX = cp.X-bxW*.5; local bxY = tp.Y
	_pvwMorph = damp(_pvwMorph, Cfg.esp.corner and 1 or 0, .08, dt)
	local fr = lerp(.5,.25,_pvwMorph)
	if Cfg.esp.boxes and _pvwDraw.corners then drawCornerBox(_pvwDraw.corners,bxX,bxY,bxW,bxH,col,Cfg.esp.boxThk,1,fr)
	else for _, ln in ipairs(_pvwDraw.corners or {}) do if ln then ln.Visible=false end end end
	if Cfg.esp.names and _pvwDraw.nm then _pvwDraw.nm.Text="Player123"; _pvwDraw.nm.Position=v2(cp.X,bxY-15); _pvwDraw.nm.Color=col; _pvwDraw.nm.Transparency=1; _pvwDraw.nm.Visible=true
	elseif _pvwDraw.nm then _pvwDraw.nm.Visible=false end
	local dY = bp.Y+3
	if Cfg.esp.dist and _pvwDraw.dstTx then _pvwDraw.dstTx.Text="[42m]"; _pvwDraw.dstTx.Position=v2(cp.X,dY); _pvwDraw.dstTx.Color=col; _pvwDraw.dstTx.Transparency=1; _pvwDraw.dstTx.Visible=true; dY+=13
	elseif _pvwDraw.dstTx then _pvwDraw.dstTx.Visible=false end
	if Cfg.esp.weapon and _pvwDraw.wpnTx then _pvwDraw.wpnTx.Text="[M4A1]"; _pvwDraw.wpnTx.Position=v2(cp.X,dY); _pvwDraw.wpnTx.Transparency=1; _pvwDraw.wpnTx.Visible=true
	elseif _pvwDraw.wpnTx then _pvwDraw.wpnTx.Visible=false end
	if Cfg.esp.hbar then
		local barW = mx(3,floor(bxW*.07)); local barX = bxX-barW-3; local fH = mx(1,bxH*.72); local hc = hpcol(.72)
		if _pvwDraw.hpOl then _pvwDraw.hpOl.Size=v2(barW+2,bxH+2); _pvwDraw.hpOl.Position=v2(barX-1,bxY-1); _pvwDraw.hpOl.Transparency=1; _pvwDraw.hpOl.Visible=true end
		if _pvwDraw.hpBg then _pvwDraw.hpBg.Size=v2(barW,bxH); _pvwDraw.hpBg.Position=v2(barX,bxY); _pvwDraw.hpBg.Transparency=.5; _pvwDraw.hpBg.Visible=true end
		if _pvwDraw.hpFl then _pvwDraw.hpFl.Size=v2(barW,fH); _pvwDraw.hpFl.Position=v2(barX,bxY+(bxH-fH)); _pvwDraw.hpFl.Color=hc; _pvwDraw.hpFl.Transparency=1; _pvwDraw.hpFl.Visible=true end
	else
		if _pvwDraw.hpOl then _pvwDraw.hpOl.Visible=false end
		if _pvwDraw.hpBg then _pvwDraw.hpBg.Visible=false end
		if _pvwDraw.hpFl then _pvwDraw.hpFl.Visible=false end
	end
	if Cfg.esp.tracers and _pvwDraw.trc then
		local va = _pvwVp.AbsolutePosition; local vs = _pvwVp.AbsoluteSize
		_pvwDraw.trc.From=v2(va.X+vs.X*.5+_inset.X,va.Y+vs.Y+_inset.Y); _pvwDraw.trc.To=cp
		_pvwDraw.trc.Color=col; _pvwDraw.trc.Transparency=1; _pvwDraw.trc.Visible=true
	elseif _pvwDraw.trc then _pvwDraw.trc.Visible=false end
	if Cfg.esp.skel and _pvwDraw.skelLn then
		for i, bone in ipairs(SKEL15) do
			local ln = _pvwDraw.skelLn[i]; if not ln then continue end
			local a, b = _pvwWm:FindFirstChild(bone[1]), _pvwWm:FindFirstChild(bone[2])
			if a and b then
				local sa,oa = vpProject(_pvwVp,_pvwCam,a.CFrame.Position); local sb,ob = vpProject(_pvwVp,_pvwCam,b.CFrame.Position)
				if oa and ob then ln.From=sa; ln.To=sb; ln.Color=col; ln.Transparency=1; ln.Visible=true else ln.Visible=false end
			else ln.Visible=false end
		end
	else for _, ln in ipairs(_pvwDraw.skelLn or {}) do if ln then ln.Visible=false end end end
end

